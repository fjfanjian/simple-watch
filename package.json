{
  "name": "simplewatch",
  "version": "0.1.0",
  "private": true,
  "description": "SimpleWatch private synchronized viewing system",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=24 <25",
    "pnpm": ">=10 <11"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "argon2",
      "better-sqlite3",
      "esbuild"
    ]
  },
  "scripts": {
    "env:check": "node tools/environment/env-check.mjs",
    "lint": "eslint . --max-warnings=0",
    "format:check": "prettier --check .",
    "typecheck": "pnpm --recursive typecheck",
    "build:web": "pnpm --filter @simplewatch/web build",
    "test:unit": "vitest run packages",
    "test:ids": "node tools/testing/validate-test-ids.mjs",
    "test:coverage": "pnpm test:media && vitest run --config vitest.coverage.config.ts --coverage",
    "audit:prod": "node tools/security/audit-bulk.mjs",
    "accounts:generate": "node tools/security/generate-account-credentials.mjs",
    "test:security": "vitest run tests/security && pnpm audit:prod",
    "test:integration": "vitest run apps/api/test tests/integration --passWithNoTests",
    "test:media": "pnpm --filter @simplewatch/media test:smoke",
    "test:worker": "pnpm --filter @simplewatch/worker test",
    "test:range": "pnpm test:media && node tools/testing/platform-gate.mjs range",
    "test:compose": "node tools/testing/compose-check.mjs",
    "test:rtc": "node tools/testing/platform-gate.mjs rtc",
    "test:backup": "node tools/testing/platform-gate.mjs backup",
    "release:manifest": "node tools/release/create-manifest.mjs",
    "test:e2e": "playwright test",
    "openapi:generate": "pnpm --filter @simplewatch/api openapi:generate",
    "openapi:check": "pnpm --filter @simplewatch/api openapi:check",
    "plan:lint": "node tools/plan-lint.mjs",
    "verify": "pnpm env:check && pnpm plan:lint && pnpm test:ids && pnpm lint && pnpm format:check && pnpm typecheck && pnpm build:web && pnpm test:unit && pnpm test:integration && pnpm test:security && pnpm test:coverage && pnpm test:media && pnpm test:worker && pnpm test:range && pnpm test:compose && pnpm test:rtc && pnpm test:backup && pnpm release:manifest && pnpm openapi:check && pnpm test:e2e"
  },
  "devDependencies": {
    "@eslint/js": "9.39.1",
    "@playwright/test": "1.61.1",
    "@types/node": "24.10.1",
    "@vitest/coverage-v8": "3.2.4",
    "eslint": "9.39.1",
    "globals": "16.5.0",
    "livekit-server-sdk": "2.17.0",
    "prettier": "3.7.4",
    "typescript": "5.9.3",
    "typescript-eslint": "8.48.1",
    "vitest": "3.2.4",
    "yaml": "2.9.0"
  }
}
